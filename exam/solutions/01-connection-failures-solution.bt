#!/usr/bin/env bpftrace
/*
 * Solution: TCP Connection Failure Tracker
 */

BEGIN
{
    printf("Tracking TCP connection failures... (Ctrl+C to stop)\n");
}

kprobe:tcp_connect
{
    @sockets[tid] = arg0;
}

kretprobe:tcp_connect
{
    if (retval < 0) {
        $sk = @sockets[tid];
        @failed_connections["failures"] = count();
    }

    delete(@sockets[tid]);
}
